{
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "target": "ESNext",
    "baseUrl": ".",
    "sourceMap": false,
    "moduleResolution": "node",
    "allowJs": false,
    "strict": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "removeComments": false,
    "rootDir": ".",
    "types": ["vite/client", "node"],
    "paths": {
      "@mengyue-plus/components": ["packages/components"],
      "@mengyue-plus/components/*": ["packages/components/*"],
      "@mengyue-plus/utils": ["packages/utils"],
      "@mengyue-plus/utils/*": ["packages/utils/*"],
      "@mengyue-plus/hooks": ["packages/hooks"],
      "@mengyue-plus/directives": ["packages/directives"],
      "@mengyue-plus/constants": ["packages/constants"],
      "@mengyue-plus/locale": ["packages/locale"],
      "@mengyue-plus/locale/*": ["packages/locale/*"],
      "mengyue-plus": ["packages/mengyue-plus"]
    },
    "preserveSymlinks": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "icons/src/**/*",
    "packages/**/*",
    "vite.config.ts",
    "vite-env.d.ts"
  ]
}