{
  // "extends": "@vue/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ESNext",
    "paths": {
      "@/*": [
        "./packages/*"
      ]
    },
    "ignoreDeprecations": "6.0",
    "verbatimModuleSyntax": true,
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.d.ts",
    "packages/**/*.tsx",
    "packages/**/*.vue",
    "docs/.vitepress/**/*.ts",
    "docs/.vitepress/**/*.d.ts",
    "docs/.vitepress/**/*.tsx",
    "docs/.vitepress/**/*.vue",
    "typings/env.d.ts"
, "docs/.vitepress/theme/index.ts"  ],
  "exclude": [
    "node_modules",
    "**/dist/**",
    "**/__tests__/**/*",
    "**/gulpfile.ts",
    "**/test-helper",
    "packages/test-utils",
    "**/*.md"
  ]
}